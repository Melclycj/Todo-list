# Copy this file to .env and fill in real values before running.
# .env is gitignored — never commit real secrets.

# ── Required ────────────────────────────────────────────────────────────────

# JWT signing key — must be a long random string in production.
# Generate one with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=change-me-generate-a-real-secret

# ── Database ─────────────────────────────────────────────────────────────────

# Postgres container credentials — used by both the db and api services.
# Generate a strong password with: python -c "import secrets; print(secrets.token_hex(32))"
POSTGRES_USER=todoapp
POSTGRES_PASSWORD=change-me-generate-a-real-password
POSTGRES_DB=todoapp

# Used by the API server (matches the db service in docker-compose.yml).
# When running via docker-compose these are auto-constructed from the vars above;
# set them here only for running the API locally outside Docker.
DATABASE_URL=postgresql+asyncpg://todoapp:change-me@localhost:5432/todoapp

# Used by integration tests
TEST_DATABASE_URL=postgresql+asyncpg://todoapp:change-me@localhost:5432/todoapp_test

# ── Optional ─────────────────────────────────────────────────────────────────

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── CORS ──────────────────────────────────────────────────────────────────────

# Comma-separated list of allowed origins for the API.
# In production set this to your real domain: https://yourdomain.com
ALLOWED_ORIGINS=http://localhost:5173
